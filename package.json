{
  "name": "@kumbuka-ai/console",
  "version": "0.5.1",
  "private": false,
  "license": "AGPL-3.0-only",
  "description": "kumbuka.ai admin console \u2014 Next.js BFF that consumes the kumbuka-backend admin API.",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kumbuka-ai/kumbuka-console.git"
  },
  "files": [
    "src",
    "public",
    "tailwind.config.ts",
    "postcss.config.mjs",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./app/*": "./src/app/*",
    "./components/*": "./src/components/*",
    "./lib/*": "./src/lib/*",
    "./i18n/*": "./src/i18n/*",
    "./messages/*": "./src/i18n/messages/*",
    "./styles/*": "./src/styles/*",
    "./middleware": "./src/middleware.ts",
    "./slots": "./src/slots/registry.ts",
    "./slots/types": "./src/slots/types.ts",
    "./routes": "./src/routes.manifest.ts",
    "./package.json": "./package.json"
  },
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "start": "next start -p 3000",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:responsive": "node e2e/responsive-overflow.mjs",
    "mutation": "stryker run",
    "slop:deps": "pnpm dlx depcheck",
    "slop:deadcode": "pnpm dlx knip",
    "slop:dup": "pnpm dlx jscpd src packages --min-lines 10 --min-tokens 50",
    "slop": "pnpm mutation && pnpm slop:deps && pnpm slop:deadcode && pnpm slop:dup"
  },
  "dependencies": {
    "lucide-react": "^0.460.0"
  },
  "peerDependencies": {
    "next": "15.5.19",
    "next-intl": "^4.9.2",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/postcss": "^4.0.0-beta.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.14.0",
    "eslint-config-next": "15.5.19",
    "jsdom": "^25.0.1",
    "next": "15.5.19",
    "next-intl": "^4.9.2",
    "postcss": "^8.4.49",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "^4.0.0-beta.3",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  },
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.7",
      "react-dom": "19.2.7",
      "postcss": ">=8.5.10"
    }
  }
}
