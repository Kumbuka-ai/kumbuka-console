# Server-side base URL the Next.js app uses to reach the backend BFF.
# In Docker compose this resolves via the internal network.
KUMBUKA_BACKEND_URL=http://kumbuka-backend:8080

# Public app name shown in titles.
NEXT_PUBLIC_APP_NAME=kumbuka.ai

# Set to "1" to bypass the backend and run on bundled mock data
# (useful while the backend is still wiring up endpoints).
KUMBUKA_API_MOCK=0
